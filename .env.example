# Required: your OpenAI Ads API key. Each key is scoped to a single ad account.
# Create one from the OpenAI Ads Manager (see the README for the link & steps).
OPENAI_ADS_API_KEY=

# Optional: override the API base URL.
# Defaults to https://api.ads.openai.com/v1
# OPENAI_ADS_BASE_URL=https://api.ads.openai.com/v1
